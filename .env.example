# Database (sqlite for local dev, postgres for production)
# For SQLite: DB_TYPE=sqlite, DATABASE_URL=sqlite+aiosqlite:///./huanyou.db
# For Postgres: DB_TYPE=postgres, DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
DB_TYPE=sqlite
DB_PASSWORD=huanyou123
DATABASE_URL=sqlite+aiosqlite:///./huanyou.db
DATABASE_URL_SYNC=sqlite:///./huanyou.db

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=huanyou

# LLM - DeepSeek (primary)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# LLM - Qwen (alternative)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# Embedding
EMBEDDING_MODEL=bge-large-zh-v1.5
# Or for cloud: text-embedding-v4

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
ENV=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Mem0
MEM0_COLLECTION=huanyou_memories
